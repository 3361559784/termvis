  "name": "termvis",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "termvis": {
      "cwd": "${workspacePath}",
      "args": [
        "${workspacePath}${/}bin${/}termvis.js",
        "mcp"
      ],
      "includeTools": [
        "termvis_probe",
        "termvis_render_card",
        "termvis_render_image",
        "termvis_life_frame",
        "termvis_soul_event",
        "termvis_soul_config"
      ]
    }
  }
}
